{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "Authority": "https://localhost:5021"
  },
  "ReverseProxy": {
    "Routes": {
      "library-route": {
        "ClusterId": "library-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/library/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "usercontent-route": {
        "ClusterId": "usercontent-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/usercontent/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "identity-wellknown-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      },
      "identity-connect-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "library-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000/"
          }
        }
      },
      "usercontent-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5010/"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5021/"
          }
        }
      }
    }
  }
}
