{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "library-route": {
        "ClusterId": "library-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/library/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "usercontent-route": {
        "ClusterId": "usercontent-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/usercontent/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "library-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6000/"
          }
        }
      },
      "usercontent-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6010/"
          }
        }
      }
    }
  }
}
