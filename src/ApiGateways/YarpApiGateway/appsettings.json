{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://blackened-death.com"
    ]
  },
  "AllowedHosts": "*",
  "RateLimiter": {
    "Window": "00:01:00",
    "PermitLimit": 100
  },
  "IdentityServer": {
    "Authority": "http://identity.server:8080"
  },
  "ReverseProxy": {
    "Routes": {
      "library-route": {
        "ClusterId": "library-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/library/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "usercontent-route": {
        "ClusterId": "usercontent-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/usercontent/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "notifications-stream-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/notifications/stream"
        },
        "Transforms": [
          { "PathPattern": "/stream" }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "identity-wellknown-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      },
      "identity-connect-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "library-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://library.api:8080/"
          }
        }
      },
      "usercontent-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://usercontent.api:8080/"
          }
        }
      },
      "notifications-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:30:00"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://notifications.api:8080/"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://identity.server:8080/"
          }
        }
      }
    }
  }
}
