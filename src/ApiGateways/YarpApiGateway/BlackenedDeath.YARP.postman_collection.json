{
  "info": {
    "name": "Blackened Death - YARP API Gateway",
    "_postman_id": "bd-yarp-gateway-collection",
    "description": "All requests routed through the YARP API Gateway (http://localhost:5050).\n\nRoutes:\n  /library/**  → Library.API  (http://localhost:6000)\n  /usercontent/** → UserContent.API (http://localhost:6010)\n\nSet the `gateway_url` variable to override the base URL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:5050",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Library",
      "description": "Library service endpoints — proxied via /library prefix",
      "item": [
        {
          "name": "Albums",
          "item": [
            {
              "name": "Get Albums",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{gateway_url}}/library/albums?pageIndex=0&pageSize=10",
                  "host": ["{{gateway_url}}"],
                  "path": ["library", "albums"],
                  "query": [
                    { "key": "pageIndex", "value": "0" },
                    { "key": "pageSize", "value": "10" }
                  ]
                },
                "description": "Returns a paginated list of albums."
              }
            },
            {
              "name": "Get Album By Id",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{gateway_url}}/library/albums/:id",
                  "host": ["{{gateway_url}}"],
                  "path": ["library", "albums", ":id"],
                  "variable": [
                    {
                      "key": "id",
                      "value": "00000000-0000-0000-0000-000000000000",
                      "description": "Album GUID"
                    }
                  ]
                },
                "description": "Returns a single album by its GUID."
              }
            },
            {
              "name": "Get Albums By Release Year",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{gateway_url}}/library/albums/releaseyear/:releaseDate",
                  "host": ["{{gateway_url}}"],
                  "path": ["library", "albums", "releaseyear", ":releaseDate"],
                  "variable": [
                    {
                      "key": "releaseDate",
                      "value": "1992",
                      "description": "4-digit release year"
                    }
                  ]
                },
                "description": "Returns all albums released in a given year."
              }
            },
            {
              "name": "Create Album",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"album\": {\n    \"id\": \"00000000-0000-0000-0000-000000000000\",\n    \"title\": \"Covenant\",\n    \"releaseDate\": 1994,\n    \"coverUrl\": null,\n    \"type\": \"FullLength\",\n    \"format\": \"CD\",\n    \"label\": \"Earache Records\",\n    \"bands\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000001\",\n        \"name\": \"Morbid Angel\"\n      }\n    ],\n    \"countries\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000002\",\n        \"name\": \"United States\"\n      }\n    ],\n    \"streamingLinks\": [\n      {\n        \"platform\": \"Spotify\",\n        \"embedCode\": \"spotify:album:example\"\n      }\n    ],\n    \"tracks\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000003\",\n        \"title\": \"Rapture\",\n        \"trackNumber\": 1\n      }\n    ],\n    \"genres\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000004\",\n        \"name\": \"Death Metal\",\n        \"parentGenreId\": null\n      }\n    ]\n  }\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{gateway_url}}/library/albums",
                  "host": ["{{gateway_url}}"],
                  "path": ["library", "albums"]
                },
                "description": "Creates a new album.\n\nAlbumType values: FullLength, EP, Demo, Single, Compilation, LiveAlbum, Split\nAlbumFormat values: CD, Digital, Vinyl, Cassette, VinylLP, VinylEP, DVD, BluRay\nStreamingPlatform values: Spotify, AppleMusic, YouTube, Deezer, SoundCloud, Tidal, AmazonMusic, Bandcamp"
              }
            },
            {
              "name": "Update Album",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"album\": {\n    \"id\": \"00000000-0000-0000-0000-000000000000\",\n    \"title\": \"Covenant (Remastered)\",\n    \"releaseDate\": 1994,\n    \"coverUrl\": \"https://example.com/cover.jpg\",\n    \"type\": \"FullLength\",\n    \"format\": \"Vinyl\",\n    \"label\": \"Earache Records\",\n    \"bands\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000001\",\n        \"name\": \"Morbid Angel\"\n      }\n    ],\n    \"countries\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000002\",\n        \"name\": \"United States\"\n      }\n    ],\n    \"streamingLinks\": [],\n    \"tracks\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000003\",\n        \"title\": \"Rapture\",\n        \"trackNumber\": 1\n      }\n    ],\n    \"genres\": [\n      {\n        \"id\": \"00000000-0000-0000-0000-000000000004\",\n        \"name\": \"Death Metal\",\n        \"parentGenreId\": null\n      }\n    ]\n  }\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{gateway_url}}/library/albums",
                  "host": ["{{gateway_url}}"],
                  "path": ["library", "albums"]
                },
                "description": "Updates an existing album. The album Id in the body identifies the record to update."
              }
            },
            {
              "name": "Delete Album",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{gateway_url}}/library/albums/:id",
                  "host": ["{{gateway_url}}"],
                  "path": ["library", "albums", ":id"],
                  "variable": [
                    {
                      "key": "id",
                      "value": "00000000-0000-0000-0000-000000000000",
                      "description": "Album GUID"
                    }
                  ]
                },
                "description": "Deletes an album by its GUID."
              }
            }
          ]
        },
