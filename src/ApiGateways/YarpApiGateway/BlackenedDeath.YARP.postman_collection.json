    {
      "name": "UserContent",
      "description": "UserContent service endpoints — proxied via /usercontent prefix",
      "item": [
        {
          "name": "Favorite Albums",
          "item": [
            {
              "name": "Add Album To Favorites",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"albumId\": \"00000000-0000-0000-0000-000000000000\",\n  \"userId\": \"00000000-0000-0000-0000-000000000001\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{gateway_url}}/usercontent/favoriteAlbums",
                  "host": ["{{gateway_url}}"],
                  "path": ["usercontent", "favoriteAlbums"]
                },
                "description": "Adds an album to a user's favorites list."
              }
            },
            {
              "name": "Remove Album From Favorites",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{gateway_url}}/usercontent/favoriteAlbums?userId=00000000-0000-0000-0000-000000000001&albumId=00000000-0000-0000-0000-000000000000",
                  "host": ["{{gateway_url}}"],
                  "path": ["usercontent", "favoriteAlbums"],
                  "query": [
                    { "key": "userId", "value": "00000000-0000-0000-0000-000000000001" },
                    { "key": "albumId", "value": "00000000-0000-0000-0000-000000000000" }
                  ]
                },
                "description": "Removes an album from a user's favorites list."
              }
            }
          ]
        },
