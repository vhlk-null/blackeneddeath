{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "IssuerUri": "",
    "Clients": [
      {
        "ClientId": "angular",
        "ClientName": "Angular Client",
        "AllowedCorsOrigins": [ "http://localhost:4200" ],
        "RedirectUris": [ "http://localhost:4200/auth/callback" ],
        "PostLogoutRedirectUris": [ "http://localhost:4200" ]
      }
    ]
  }
}