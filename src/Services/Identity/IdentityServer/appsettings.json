{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://blackened-death.com" ]
  },
  "IdentityServer": {
    "IssuerUri": "",
    "Clients": [
      {
        "ClientId": "angular",
        "ClientName": "Angular Client",
        "AccessTokenLifetime": 3600,
        "AllowedCorsOrigins": [ "https://blackened-death.com" ],
        "RedirectUris": [ "https://blackened-death.com/auth/callback" ],
        "PostLogoutRedirectUris": [ "https://blackened-death.com" ]
      }
    ]
  }
}