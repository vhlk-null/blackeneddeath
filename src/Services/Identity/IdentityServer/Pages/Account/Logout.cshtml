@page
@model IdentityServer.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Logged Out";
}

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Logged Out — Blackened Death Metal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --color-bg:           #060708;
      --color-header-bg:    #161616;
      --color-border:       rgba(255,255,255,0.08);
      --color-text:         rgba(255,255,255,0.7);
      --color-text-heading: #E3EAFF;
      --color-text-muted:   #B2B2B2;
      --color-border-input: #2A2A2A;
      --font-heading:       'Cinzel', serif;
      --font-body:          'Inter', sans-serif;
      --radius-md:          6px;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background-color: var(--color-bg);
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.5;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ──────────────────────────────────────────── */
    .site-header {
      background: var(--color-header-bg);
      border-bottom: 1px solid var(--color-border);
      height: 4rem;
      display: flex;
      align-items: center;
      padding: 0 2rem;
    }

    .site-header__logo {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: 0.085em;
      color: var(--color-text-muted);
      text-decoration: none;
    }

    /* ── Page layout ─────────────────────────────────────── */
    .page {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    /* ── Card ────────────────────────────────────────────── */
    .logout-card {
      background: #161616;
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 2.5rem 2rem 2rem;
      width: min(26rem, calc(100vw - 2rem));
      text-align: center;
      animation: scale-in 0.25s ease;
    }

    .logout-card__icon {
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      width: 3.5rem;
      height: 3.5rem;
      border-radius: 50%;
      border: 1px solid var(--color-border-input);
    }

    .logout-card__icon svg {
      width: 1.5rem;
      height: 1.5rem;
      color: var(--color-text-muted);
    }

    .logout-card__title {
      margin: 0 0 0.5rem;
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      color: var(--color-text-heading);
      letter-spacing: 0.06em;
    }

    .logout-card__text {
      margin: 0 0 2rem;
      font-family: var(--font-body);
      font-size: 0.875rem;
      color: var(--color-text-muted);
    }

    .logout-card__link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 2.75rem;
      padding: 0 2rem;
      background: var(--color-text-heading);
      color: var(--color-bg);
      border-radius: var(--radius-md);
      font-family: var(--font-heading);
      font-size: 0.9375rem;
      letter-spacing: 0.08em;
      text-decoration: none;
      transition: opacity 0.15s ease;
    }

    .logout-card__link:hover {
      opacity: 0.85;
    }

    .logout-card__spinner {
      display: inline-block;
      width: 2rem;
      height: 2rem;
      border: 2px solid var(--color-border);
      border-top-color: var(--color-text-muted);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-bottom: 1.5rem;
    }

    @@keyframes scale-in {
      from { opacity: 0; transform: scale(0.97) translateY(-6px); }
      to   { opacity: 1; transform: scale(1)    translateY(0); }
    }

    @@keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>

  <header class="site-header">
    <a class="site-header__logo" href="http://localhost:4200">Blackened Death Metal</a>
  </header>

  <main class="page">
    <div class="logout-card">

      @if (Model.ShowSignedOutPage)
      {
        <div class="logout-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
            <polyline points="16 17 21 12 16 7" />
            <line x1="21" y1="12" x2="9" y2="12" />
          </svg>
        </div>

        <h1 class="logout-card__title">Signed Out</h1>
        <p class="logout-card__text">You have been successfully signed out.</p>

        @if (Model.PostLogoutRedirectUri != null)
        {
          <a class="logout-card__link" href="@Model.PostLogoutRedirectUri">Return to site</a>
        }
      }
      else
      {
        <div class="logout-card__spinner"></div>
        <h1 class="logout-card__title">Signing Out...</h1>
        <p class="logout-card__text">Please wait a moment.</p>
      }

    </div>
  </main>

</body>
</html>
